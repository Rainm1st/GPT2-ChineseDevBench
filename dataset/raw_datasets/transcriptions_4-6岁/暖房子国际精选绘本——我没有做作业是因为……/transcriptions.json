    "audio_file": "第6页音频_40bc730d2e3e0918646be34d9e534d64.mp3",
    "text": "我被外星人绑架了。"
  },
  {
    "page_info": "第7页音频",
    "audio_file": "第7页音频_fe349f27c1af45aab7e3939e97675488.mp3",
